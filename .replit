modules = ["nodejs-20", "python-3.12", "web"]
[nix]
channel = "stable-25_05"

[agent]
expertMode = true
stack = "BEST_EFFORT_FALLBACK"

[userenv]

[userenv.shared]
PORT = "8080"
LOG_LEVEL = "info"
APP_NAME = "XpressProFx"
ALLOWED_ORIGINS = "https://xpressprofx.com,https://www.xpressprofx.com"
NODE_ENV = "development"
COREPACK_ENABLE_STRICT = "0"

[workflows]

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3002

[[ports]]
localPort = 8083
externalPort = 3003

[[ports]]
localPort = 25580
externalPort = 3001

[[ports]]
localPort = 25849
externalPort = 3000
