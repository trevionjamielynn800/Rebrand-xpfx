# Railway/Production Environment Variables

# === REQUIRED ===
PORT=8080
NODE_ENV=production
LOG_LEVEL=info

# === DATABASE ===
DATABASE_URL=postgresql://user:password@localhost:5432/xpresspro

# === SESSION & AUTHENTICATION ===
SESSION_SECRET=your-secret-session-key-here-min-32-chars
JWT_SECRET=your-secret-jwt-key-here-min-32-chars

# === CORS & ORIGINS ===
ALLOWED_ORIGINS=https://yourdomain.com,https://admin.yourdomain.com

# === PAYMENTS (Optional) ===
MOONPAY_API_KEY=
COINBASE_WEBHOOK_SECRET=

# === EMAIL (Optional) ===
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# === AI (Optional) ===
OPENAI_API_KEY=

# === ADMIN ACCOUNT ===
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
