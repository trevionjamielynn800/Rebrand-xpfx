function gracefulShutdown(signal) {
  console.log(`[shutdown] ${signal} received`);
  server.close(() => {
    console.log('[shutdown] HTTP server closed');
    process.exit(0);
  });
  // Force exit after 15 seconds
  setTimeout(() => process.exit(1), 15000);
}

