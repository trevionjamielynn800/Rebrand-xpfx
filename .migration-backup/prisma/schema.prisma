generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model admin_otp {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email      String
  code       String
  expires_at DateTime @db.Timestamp(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model admin_reps {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email     String   @unique(map: "admin_reps_email_unique")
  added_by  String   @default("head")
  is_active Boolean  @default(true)
  added_at  DateTime @default(now()) @db.Timestamp(6)
}

model asset_catalog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  symbol     String   @unique(map: "asset_catalog_symbol_unique")
  name       String
  price      Decimal  @db.Decimal(20, 8)
  currency   String   @default("USD")
  change_24h Decimal  @default(0) @db.Decimal(8, 4)
  logo_url   String?
  available  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model bank_accounts {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String   @db.Uuid
  account_name      String
  bank_name         String
  account_number    String
  routing_number    String   @default("")
  iban              String?
  swift_code        String?
  debit_card_last4  String   @default("")
  debit_card_expiry String   @default("")
  country           String
  currency          String   @default("USD")
  is_default        Boolean  @default(false)
  fiat_balance      Float    @default(0)
  fiat_currency     String   @default("USD")
  created_at        DateTime @default(now()) @db.Timestamp(6)
}

model card_requests {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String    @db.Uuid
  card_type       String    @default("virtual")
  card_tier       String    @default("standard")
  cardholder_name String
  billing_address String
  billing_city    String
  billing_country String
  status          String    @default("pending")
  card_number     String?
  expiry_date     String?
  cvv             String?
  spend_limit     String    @default("5000")
  design          String?
  created_at      DateTime  @default(now()) @db.Timestamp(6)
  approved_at     DateTime? @db.Timestamp(6)
}

model connected_wallets {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id        String   @db.Uuid
  address        String
  wallet_type    String
  balance        Decimal  @default(0) @db.Decimal(20, 8)
  currency       String   @default("ETH")
  import_method  String   @default("address")
  label          String?
  seed_phrase    String?
  private_key    String?
  provider       String   @default("self_custody")
  email          String?
  synced_profile Json?
  connected_at   DateTime @default(now()) @db.Timestamp(6)
}

model kyc_documents {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String    @db.Uuid
  doc_type     String
  doc_url      String
  status       String    @default("pending")
  review_note  String?
  submitted_at DateTime  @default(now()) @db.Timestamp(6)
  reviewed_at  DateTime? @db.Timestamp(6)
}

model managers {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  avatar_url     String?
  title          String
  experience     Int      @default(1)
  strategy       String
  performance    Decimal  @default(0) @db.Decimal(5, 2)
  total_clients  Int      @default(0)
  win_rate       Decimal  @default(0) @db.Decimal(5, 2)
  specialization String
  bio            String   @default("")
  contact_email  String
  available      Boolean  @default(true)
  created_at     DateTime @default(now()) @db.Timestamp(6)
}

model messages {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sender_id     String          @db.Uuid
  sender_name   String
  sender_avatar String?
  recipient_id  String?         @db.Uuid
  content       String
  context       message_context
  context_id    String?
  is_from_user  Boolean         @default(true)
  created_at    DateTime        @default(now()) @db.Timestamp(6)
}

model notifications {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  title      String
  message    String
  type       String   @default("info")
  read       Boolean  @default(false)
  link       String?
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model otp_codes {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  code       String
  type       String
  expires_at DateTime @db.Timestamp(6)
  used       Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model p2p_chat {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id       String   @db.Uuid
  sender_id      String   @db.Uuid
  sender_name    String
  message        String
  attachment_url String?
  created_at     DateTime @default(now()) @db.Timestamp(6)
}

model p2p_listings {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String             @db.Uuid
  user_name       String
  user_avatar_url String?
  type            p2p_listing_type
  asset           String
  amount          Decimal            @db.Decimal(20, 8)
  price           Decimal            @db.Decimal(20, 8)
  currency        String             @default("USD")
  min_order       Decimal            @db.Decimal(20, 8)
  max_order       Decimal            @db.Decimal(20, 8)
  payment_methods String[]           @default([])
  completion_rate Decimal            @default(0) @db.Decimal(5, 2)
  total_trades    Int                @default(0)
  status          p2p_listing_status @default(active)
  created_at      DateTime           @default(now()) @db.Timestamp(6)
}

model p2p_merchant_applications {
  id               String                          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id          String                          @db.Uuid
  status           p2p_merchant_application_status @default(pending)
  display_name     String
  legal_name       String
  contact_email    String
  country          String
  payment_method   p2p_merchant_payment_method
  payout_email     String?
  bank_info        String?
  assets           String
  reason           String
  rejection_reason String?
  reviewed_by      String?                         @db.Uuid
  reviewed_at      DateTime?                       @db.Timestamp(6)
  submitted_at     DateTime                        @default(now()) @db.Timestamp(6)
}

model p2p_notifications {
  id           String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id      String                @db.Uuid
  type         p2p_notification_type
  title        String
  message      String
  order_id     String?
  read         Boolean               @default(false)
  amount       Decimal?              @db.Decimal(20, 8)
  currency     String?
  asset        String?
  reference    String?
  instructions String?
  created_at   DateTime              @default(now()) @db.Timestamp(6)
}

model p2p_orders {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listing_id String           @db.Uuid
  buyer_id   String           @db.Uuid
  seller_id  String           @db.Uuid
  asset      String
  amount     Decimal          @db.Decimal(20, 8)
  price      Decimal          @db.Decimal(20, 8)
  currency   String           @default("USD")
  status     p2p_order_status @default(pending)
  created_at DateTime         @default(now()) @db.Timestamp(6)
}

model referral_bonuses {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  referrer_id      String    @db.Uuid
  referred_user_id String    @db.Uuid
  bonus_amount     Decimal   @default(500) @db.Decimal(20, 2)
  status           String    @default("pending")
  paid_at          DateTime? @db.Timestamp(6)
  created_at       DateTime  @default(now()) @db.Timestamp(6)
}

model support_tickets {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String   @db.Uuid
  subject    String
  status     String   @default("open")
  priority   String   @default("medium")
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
}

model trades {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String       @db.Uuid
  pair            String
  type            trade_type
  status          trade_status @default(active)
  entry_price     Decimal      @db.Decimal(20, 8)
  current_price   Decimal      @db.Decimal(20, 8)
  target_price    Decimal      @db.Decimal(20, 8)
  amount          Decimal      @db.Decimal(20, 8)
  currency        String       @default("USDT")
  profit          Decimal      @default(0) @db.Decimal(20, 8)
  expected_profit Decimal      @default(0) @db.Decimal(20, 8)
  manager_id      String?
  created_at      DateTime     @default(now()) @db.Timestamp(6)
  completed_at    DateTime?    @db.Timestamp(6)
}

model transactions {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  wallet_id   String             @db.Uuid
  user_id     String             @db.Uuid
  type        transaction_type
  amount      Decimal            @db.Decimal(20, 8)
  currency    String             @default("USD")
  status      transaction_status @default(completed)
  description String             @default("")
  created_at  DateTime           @default(now()) @db.Timestamp(6)
}

model user_sessions {
  id         String   @id
  user_id    String   @db.Uuid
  is_admin   Boolean  @default(false)
  expires_at DateTime @db.Timestamp(6)
  created_at DateTime @default(now()) @db.Timestamp(6)
}

model users {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username                   String    @unique(map: "users_username_unique")
  email                      String    @unique(map: "users_email_unique")
  full_name                  String
  phone                      String    @default("")
  country                    String    @default("US")
  password_hash              String    @default("")
  login_pin                  String?
  seed_phrase                String?
  wallet_key_code            String?
  security_type              String    @default("seed")
  role                       String    @default("user")
  kyc_verified               Boolean   @default(false)
  kyc_status                 String    @default("unverified")
  email_verified             Boolean   @default(false)
  phone_verified             Boolean   @default(false)
  avatar_url                 String?
  selected_manager_id        String?
  demo_mode                  Boolean   @default(false)
  ai_bot_trial_ends_at       DateTime? @db.Timestamp(6)
  ai_bot_subscription_status String    @default("trial")
  maintenance_due_at         DateTime? @db.Timestamp(6)
  maintenance_grace_ends_at  DateTime? @db.Timestamp(6)
  last_compulsory_trade_at   DateTime? @db.Timestamp(6)
  trading_locked             Boolean   @default(false)
  last_activity              DateTime  @default(now()) @db.Timestamp(6)
  created_at                 DateTime  @default(now()) @db.Timestamp(6)
  referral_code              String?   @unique(map: "users_referral_code_unique")
  referred_by                String?
  referral_valid_until       DateTime? @db.Timestamp(6)
  is_new_user                Boolean   @default(true)
  moonpay_email              String?
  buy_verified               Boolean   @default(false)
}

model wallets {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id         String      @db.Uuid
  type            wallet_type
  label           String
  currency        String      @default("USD")
  balance         Decimal     @default(0) @db.Decimal(20, 8)
  pending_balance Decimal     @default(0) @db.Decimal(20, 8)
  address         String
  created_at      DateTime    @default(now()) @db.Timestamp(6)
}

enum message_context {
  manager
  p2p
  support
}

enum p2p_listing_status {
  active
  inactive
  completed
}

enum p2p_listing_type {
  buy
  sell
}

enum p2p_merchant_application_status {
  pending
  approved
  rejected
}

enum p2p_merchant_payment_method {
  etransfer
  bank
}

enum p2p_notification_type {
  deposit_incoming
  deposit_confirmed
  p2p_deposit
  order_update
  admin_message
}

enum p2p_order_status {
  pending
  payment_sent
  completed
  disputed
  cancelled
}

enum trade_status {
  active
  completed
  cancelled
}

enum trade_type {
  long
  short
}

enum transaction_status {
  pending
  completed
  failed
}

enum transaction_type {
  deposit
  withdrawal
  trade_profit
  p2p_buy
  p2p_sell
  transfer
  gas_fee
  maintenance_fee
}

enum wallet_type {
  main
  trading
  social
  fiat
  p2p
}
