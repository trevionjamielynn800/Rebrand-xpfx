{
  "name": "rebranded-xpfx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0",
    "pnpm": ">=10.0.0"
  },
  "workspaces": [
    "artifacts/api-server",
    "artifacts/nextrade",
    "artifacts/admin-portal",
    "artifacts/mockup-sandbox",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db"
  ],
  "scripts": {
    "generate:secrets": "node scripts/generate-secrets.mjs",
    "generate:pitch-deck": "node scripts/generate-pitch-deck.mjs",
    "postinstall": "node scripts/generate-secrets.mjs && node scripts/fix-date-fns.mjs",
    "predeploy": "node scripts/predeploy.mjs --skip-env-check",
    "build": "pnpm run build --workspaces --if-present",
    "build:all": "pnpm run build --workspace artifacts/api-server && pnpm run build --workspace artifacts/nextrade && pnpm run build --workspace artifacts/admin-portal",
    "start": "pnpm run build --workspaces --if-present && node artifacts/api-server/dist/index.mjs",
    "start:prod": "NODE_ENV=production pnpm run build --workspaces --if-present && NODE_ENV=production node artifacts/api-server/dist/index.mjs",
    "dev": "pnpm run dev --workspaces --if-present",
    "lint": "eslint . --config eslint.config.cjs --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "test": "pnpm run build --workspace artifacts/api-server && node --test tests/**/*.test.mjs",
    "pm2:install": "pnpm add -g pm2 || true",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:save": "pm2 save"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prisma": "^5.14.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "es5-ext"
    ]
  }
}
