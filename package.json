{
  "name": "rebranded-xpfx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "artifacts/api-server",
    "artifacts/nextrade",
    "artifacts/admin-portal"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "start": "node artifacts/api-server/dist/index.js",
    "start:prod": "NODE_ENV=production node artifacts/api-server/dist/index.js",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.4.5"
  }
}
