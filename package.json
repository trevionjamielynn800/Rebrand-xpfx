{
  "name": "rebranded-xpfx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "artifacts/api-server",
    "artifacts/nextrade",
    "artifacts/admin-portal",
    "artifacts/mockup-sandbox",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db"
  ],
  "scripts": {
    "postinstall": "node scripts/fix-date-fns.mjs",
    "predeploy": "node scripts/predeploy.mjs --skip-env-check",
    "build": "npm run build --workspaces --if-present",
    "start": "npm run build --workspaces --if-present && node artifacts/api-server/dist/index.mjs",
    "start:prod": "NODE_ENV=production npm run build --workspaces --if-present && NODE_ENV=production node artifacts/api-server/dist/index.mjs",
    "dev": "npm run dev --workspaces --if-present",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "pm2:install": "npm i -g pm2 || true",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:save": "pm2 save"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prisma": "^5.14.0",
    "typescript": "^5.4.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "es5-ext"
    ]
  }
}
