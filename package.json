{
  "name": "rebranded-xpfx",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "workspaces": [
    "artifacts/api-server",
    "artifacts/nextrade",
    "artifacts/admin-portal",
    "artifacts/mockup-sandbox",
    "lib/api-client-react",
    "lib/api-zod",
    "lib/db"
  ],
  "scripts": {
    "generate:secrets": "node scripts/generate-secrets.mjs",
    "generate:pitch-deck": "node scripts/generate-pitch-deck.mjs",
    "postinstall": "node scripts/generate-secrets.mjs && node scripts/fix-date-fns.mjs && prisma generate",
    "predeploy": "node scripts/predeploy.mjs --skip-env-check",
    "build": "npm run build --workspace=artifacts/api-server && npm run build --workspace=artifacts/nextrade && npm run build --workspace=artifacts/admin-portal && npm run build --workspace=lib/api-zod",
    "build:all": "npm run build",
    "start": "npm run build && node artifacts/api-server/dist/index.mjs",
    "start:prod": "NODE_ENV=production npm run build && NODE_ENV=production node artifacts/api-server/dist/index.mjs",
    "dev": "npm run dev --workspaces --if-present",
    "preview": "npm run preview --workspaces --if-present",
    "dev:admin": "npm --workspace=artifacts/admin-portal run dev -- --port 5173",
    "dev:nextrade": "npm --workspace=artifacts/nextrade run dev -- --port 5174",
    "dev:mockup": "npm --workspace=artifacts/mockup-sandbox run dev -- --port 5175",
    "dev:api": "PORT=5000 npm run dev --workspace=artifacts/api-server",
    "dev:all": "npm run dev:admin & npm run dev:nextrade & npm run dev:mockup || true",
    "lint": "eslint . --config eslint.config.cjs --ext .ts,.tsx,.js,.jsx",
    "typecheck": "tsc --noEmit",
    "test": "npm run build --workspace=artifacts/api-server && node --import tsx tests/app-readiness.test.mjs && node --import tsx tests/production-env.test.mjs",
    "pm2:install": "npm install -g pm2 || true",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:save": "pm2 save"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prisma": "5.14.0",
    "@prisma/client": "5.14.0",
    "tsx": "^4.23.1",
    "typescript": "^5.4.5",
    "husky": "^9.0.0"
  }
}
