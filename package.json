{
  "name": "xpressfx-workspace-root",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "artifacts/api-server",
    "artifacts/admin-portal",
    "artifacts/mockup-sandbox",
    "artifacts/nextrade",
    "lib/db",
    "lib/api-zod",
    "lib/api-spec",
    "lib/api-client-react"
  ],
  "scripts": {
    "build": "npm run build -w @workspace/api-server",
    "start": "npm run start -w @workspace/api-server",
    "dev": "npm run dev -w @workspace/api-server",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "overrides": {
    "esbuild": "0.27.3",
    "lodash": "4.18.1",
    "yaml": "2.8.3",
    "postcss": "8.5.10",
    "micromatch": {
      "picomatch": "2.3.2"
    },
    "vite": {
      "picomatch": "4.0.4"
    },
    "router": {
      "path-to-regexp": "8.4.0"
    },
    "minimatch": {
      "brace-expansion": "2.0.3"
    }
  }
}