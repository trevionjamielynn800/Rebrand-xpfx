  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.0",
    "@types/bcryptjs": "^2.4.6",
    "typescript": "^5.4.5",
    "ts-node-dev": "^2.0.0",
