{
  "name": "xpresspro-fx-api-server",
  "version": "1.0.0",
  "description": "XpressPro FX — Enterprise-grade hybrid fintech forex broker trading and investment API server",
  "main": "dist/index.mjs",
  "scripts": {
    "build": "node ./build.mjs",
    "typecheck": "tsc --noEmit",
    "start": "node --enable-source-maps dist/index.mjs",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "postinstall": "prisma generate --schema=./prisma/schema.prisma || true",
    "test": "jest --forceExit --coverage",
    "audit": "npm audit --audit-level=high"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "@workspace/api-zod": "^1.0.0",
    "@workspace/db": "^0.0.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.45.2",
    "ethers": "^6.0.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "express-rate-limit": "^7.3.1",
    "express-validator": "^7.1.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "openai": "^4.0.0",
    "pg": "^8.20.0",
    "pino": "^9.2.0",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.1",
    "prisma": "5.14.0",
    "prom-client": "^14.0.1",
    "uuid": "^14.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "esbuild": "0.25.8",
    "esbuild-plugin-pino": "^2.2.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.2"
  }
}
